#!/usr/bin/env bash
set -euo pipefail

# Define Borg Repository
export BORG_REPO="{{ borg_repository }}"
export BORG_UNKNOWN_UNENCRYPTED_REPO_ACCESS_IS_OK=yes


# Ensure the mount point is active (trigger automount by accessing it)
ls "${BORG_REPO}" >/dev/null 2>&1 || true

# Verify that the Borg config file exists (confirming mount is active)
if [[ ! -f "${BORG_REPO}/config" ]]; then
    echo "⚠️ Error: Borg repository is not accessible. Is the NAS mounted?" >&2
    exit 1
fi

# Avoid failing due to locks left by previous suspended/interrupted sleep states of the same host
lock_dir="${BORG_REPO}/lock.exclusive"
if [[ -d "${lock_dir}" ]]; then
    lock_file=$(find "${lock_dir}" -maxdepth 1 -type f -print -quit)
    if [[ -n "${lock_file}" ]]; then
        lock_filename=$(basename "${lock_file}")
        lock_host="${lock_filename%%@*}"
        current_host=$(hostname)
        if { [[ "${lock_host}" == "${current_host}" ]] || [[ "${lock_host}" == "pop-os" ]]; } && ! pgrep -x borg >/dev/null; then
            echo "⚠️ Found stale lock from host '${lock_host}' (PID not running). Breaking lock..."
            borg break-lock "${BORG_REPO}"
        fi
    fi
fi

echo "🚀 Starting BorgBackup process..."

# Run Borg create
borg create \
    --stats \
    --progress \
    --compression lz4 \
    ::"backup-$(date +%Y-%m-%d-%H%M%S)" \
    {% for source in borg_backup_sources %}
    "{{ source }}"{% if not loop.last %} \
{% endif %}{% endfor %}



echo "🧹 Pruning old archives..."
borg prune \
    --list \
    --keep-daily=7 \
    --keep-weekly=4 \
    --keep-monthly=12

echo "✅ Backup process complete!"
